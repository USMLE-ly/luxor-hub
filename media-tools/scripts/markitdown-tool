#!/usr/bin/env bash
# markitdown-tool — Convert any file to Markdown
set -euo pipefail

VENV="/root/Documents/Codex/2026-06-08/make-the-deepseek-v4-flash-free/.venv"
source "$VENV/bin/activate"

if [ $# -eq 0 ]; then
    echo "Usage: markitdown-tool <input-file> [output-file]"
    echo "Converts any supported file (PDF, DOCX, PPTX, XLSX, image, audio, HTML, EPUB) to Markdown."
    echo ""
    echo "Examples:"
    echo "  markitdown-tool document.pdf            # prints markdown to stdout"
    echo "  markitdown-tool document.docx output.md  # writes to file"
    exit 1
fi

INPUT="$1"
OUTPUT="${2:-}"

if [ -n "$OUTPUT" ]; then
    markitdown "$INPUT" > "$OUTPUT"
    echo "Written to: $OUTPUT"
else
    markitdown "$INPUT"
fi
