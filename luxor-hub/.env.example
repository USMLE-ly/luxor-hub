# Supabase — get these from https://app.supabase.com → Project Settings → API
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Backend API
VITE_API_URL=http://localhost:5000

# PayPal — get these from https://developer.paypal.com
VITE_PAYPAL_CLIENT_ID=your-client-id
VITE_PAYPAL_STARTER_PLAN_ID=P-XXXXXXXXXX
VITE_PAYPAL_PRO_PLAN_ID=P-XXXXXXXXXX
VITE_PAYPAL_ELITE_PLAN_ID=P-XXXXXXXXXX

# Prisma (only needed for direct DB access)
DATABASE_URL=postgresql://user:pass@host:5432/dbname
DIRECT_URL=postgresql://user:pass@host:5432/dbname
