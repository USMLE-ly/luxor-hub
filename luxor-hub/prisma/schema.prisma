generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model CalendarEvents {
  id String @id @default(uuid())
  userId String
  title String
  eventDate DateTime
  eventTime DateTime?
  occasion String?
  notes String?
  outfitItems Json?
  outfitData Json?
  outfitType String?
  mannequinImageUrl String?
  badgeKey String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChallengeEntries {
  id String @id @default(uuid())
  userId String
  challengeId String?
  analysisId String?
  read Boolean?
  createdAt DateTime @default(now())
}

model ChatMessages {
  id String @id @default(uuid())
  userId String
  role String
  content String?
  metadata Json?
  createdAt DateTime @default(now())
}

model ClothingItems {
  id String @id @default(uuid())
  userId String
  name String?
  category String?
  color String?
  brand String?
  style String?
  season String?
  occasion String?
  price Float?
  photoUrl String?
  notes String?
  wearCount Int?
  lastWornAt DateTime?
  isPublic Boolean?
  lookType String?
  badgeKey String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CouncilConversations {
  id String @id @default(uuid())
  userId String
  title String?
  messages Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FashionDesigns {
  id String @id @default(uuid())
  userId String
  prompt String?
  imageUrl String?
  description String?
  garmentType String?
  isFavorite Boolean?
  isPublic Boolean?
  lookType String?
  lookId String?
  outfitId String?
  createdAt DateTime @default(now())
}

model Follows {
  id String @id @default(uuid())
  followerId String
  followingId String
  createdAt DateTime @default(now())
}

model LookComments {
  id String @id @default(uuid())
  userId String
  lookId String?
  lookType String?
  content String?
  isPublic Boolean?
  garmentType String?
  createdAt DateTime @default(now())
}

model LookLikes {
  id String @id @default(uuid())
  userId String
  lookId String?
  lookType String?
  isPublic Boolean?
  garmentType String?
  outfitId String?
  followerId String?
  followingId String?
  createdAt DateTime @default(now())
}

model MannequinState {
  id String @id @default(uuid())
  userId String @unique
  gender String
  dna Json
  pose String
  tracingUrl String?
  tracingOpacity Float
  showMeasurements Boolean
  clothing Json
  updatedAt DateTime @updatedAt
}

model MoodBoardItems {
  id String @id @default(uuid())
  boardId String
  userId String
  positionX Float?
  positionY Float?
  createdAt DateTime @default(now())
}

model MoodBoards {
  id String @id @default(uuid())
  userId String
  name String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NewsletterSubscribers {
  id String @id @default(uuid())
  email String @unique
  createdAt DateTime @default(now())
}

model Notifications {
  id String @id @default(uuid())
  userId String
  actorId String
  type String
  referenceId String?
  read Boolean?
  createdAt DateTime @default(now())
}

model OutfitAnalyses {
  id String @id @default(uuid())
  userId String
  imageUrl String?
  category String?
  color String?
  style String?
  detectedItems Json?
  overallStyle String?
  styleScore Int?
  colorPalette Json?
  strengths Json?
  summary String?
  challengeId String?
  createdAt DateTime @default(now())
}

model OutfitItems {
  id String @id @default(uuid())
  outfitId String
  clothingItemId String?
  userId String
  lookType String?
  isPublic Boolean?
  createdAt DateTime @default(now())
}

model Outfits {
  id String @id @default(uuid())
  userId String
  name String?
  description String?
  occasion String?
  mood String?
  mannequinItems Json?
  aiExplanation String?
  aiGenerated Boolean?
  confidenceScore Float?
  isFavorite Boolean?
  isPublic Boolean?
  lookType String?
  badgeKey String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Profiles {
  id String @id @default(uuid())
  displayName String?
  avatarUrl String?
  styleFormula String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SavedLooks {
  id String @id @default(uuid())
  userId String
  lookId String?
  lookType String?
  isPublic Boolean?
  createdAt DateTime @default(now())
}

model StyleProfiles {
  id String @id @default(uuid())
  userId String @unique
  archetype String?
  styleScore Int?
  styleFormula String?
  onboardingCompleted Boolean?
  preferences Json?
  bodyShapeData Json?
  faceShapeData Json?
  aiAnalysis Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscriptions {
  id String @id @default(uuid())
  userId String @unique
  planTier String
  status String
  paypalSubscriptionId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserBadges {
  id String @id @default(uuid())
  userId String
  badgeKey String
  badgeName String?
  badgeDescription String?
  badgeIcon String?
  read Boolean?
  awardedAt DateTime?
}

model UserLooks {
  id String @id @default(uuid())
  userId String
  title String?
  description String?
  photoUrl String?
  occasion String?
  mood String?
  items Json?
  isPublic Boolean?
  lookType String?
  lookId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WearLogs {
  id String @id @default(uuid())
  userId String
  clothingItemId String?
  wornAt DateTime?
  category String?
  createdAt DateTime @default(now())
}

model WeeklyChallenges {
  id String @id @default(uuid())
  title String?
  description String?
  startDate DateTime?
  endDate DateTime?
  createdAt DateTime @default(now())
}
