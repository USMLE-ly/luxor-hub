#!/usr/bin/env bash
# media-tools — Central launcher for all media/document tools
set -euo pipefail

VENV="/root/Documents/Codex/2026-06-08/make-the-deepseek-v4-flash-free/.venv"
source "$VENV/bin/activate"

show_help() {
    echo "Media & Document Tools — Annihilation LLM Suite"
    echo ""
    echo "Usage: media-tools <command> [args...]"
    echo ""
    echo "Commands:"
    echo "  markitdown <file> [output]          Convert any document to Markdown"
    echo "  pdf-extract <file> [opts]           Extract text/tables from PDFs"
    echo "  turbovec build/search <args...>     Vector ANN index building & search"
    echo "  quantmind info|modules|extract      QuantMind financial data extraction"
    echo "  supermemory store/search/recall     Memory & Context Engine"
    echo "  sharp resize/convert/info/rotate    High-performance image processing"
    echo "  pro ask|coder|research|analyst      Professional mode (deepseek PRO)"
    echo "  instatakker start|info|status       Instagram engagement workflow"
    echo "  ig email|signup|full|verify         Instagram account creator + verifier"
    echo "  bot login|follow|like|view           ZORG-Ω InstaBot automation engine"
    echo "  email generate|inbox|wait            Temporary email generator (Guerrilla Mail)"
    echo ""
    echo "Aliases:"
    echo "  convert  → markitdown     vec  → turbovec      pdf  → pdf-extract"
    echo "  memory   → supermemory    img  → sharp"
    echo "  pro      → pro-tool       insta → instatakker      bot  → bot-tool      email → email-tool      ig   → ig-tool"
    echo ""
    echo "Other:"
    echo "  api|chat <prompt>                   Query deepseek-v4-flash-free via OpenCode Zen"
    echo ""
    echo "Examples:"
    echo "  media-tools markitdown document.docx output.md"
    echo "  media-tools sharp resize photo.jpg thumb.jpg 200"
    echo "  media-tools pro coder 'build a REST API'"
    echo "  media-tools instatakker info"
}

if [ $# -eq 0 ]; then
    show_help
    exit 0
fi

CMD="$1"
shift

case "$CMD" in
    markitdown|convert)     exec markitdown-tool "$@" ;;
    pdf-extract|pdf)        exec pdf-extract-tool "$@" ;;
    turbovec|vec)           exec turbovec-tool "$@" ;;
    quantmind)              exec quantmind-tool "$@" ;;
    supermemory|memory)     exec supermemory-tool "$@" ;;
    sharp|img)              exec sharp-tool "$@" ;;
    jb|jailbreak)           exec jb-tool "$@" ;;
    quora|quora-tool)     exec quora-tool "$@" ;;
    omega)              exec omega "$@" ;;
    pro|pro-tool)           exec pro-tool "$@" ;;
    instatakker|insta)      exec instatakker-tool "$@" ;;
    ig|ig-tool)            exec ig-tool "$@" ;;
    zorg|zorg-engine)    exec zorg-engine "$@" ;;
    bot|instabot)          exec bot-tool "$@" ;;
    email|email-tool)        exec email-tool "$@" ;;
    api|chat)               exec python3 "$(dirname "$(readlink -f "$0")")/../../../api_interact.py" "$@" ;;
    help|--help|-h)         show_help ;;
    *)                      echo "Unknown command: $CMD"; show_help; exit 1 ;;
esac

