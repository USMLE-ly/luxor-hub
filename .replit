run = ["gunicorn", "main:app", "--bind", "0.0.0.0:5000", "--timeout", "120", "--worker-tmp-dir", "/dev/shm", "--log-level", "warning"]
modules = ["python-3.11"]

[agent]
expertMode = true

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "main:app", "--bind", "0.0.0.0:5000", "--reuse-port", "--preload", "--timeout=120", "--worker-tmp-dir", "/dev/shm", "--log-level", "warning"]

[nix]
packages = ["glibcLocales", "libGL", "libGLU"]

[[ports]]
localPort = 5000
externalPort = 80

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = ["gunicorn", "main:app", "--bind", "0.0.0.0:5000", "--reuse-port", "--preload", "--timeout=120", "--worker-tmp-dir", "/dev/shm", "--log-level", "warning"]
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

