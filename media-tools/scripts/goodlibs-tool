#!/usr/bin/env bash
# goodlibs-tool — Download books from Goodreads shelf via Library Genesis
set -euo pipefail

VENV="/root/Documents/Codex/2026-06-08/make-the-deepseek-v4-flash-free/.venv"
source "$VENV/bin/activate"

show_help() {
    echo "goodlibs — Download books from Goodreads shelf via Library Genesis"
    echo ""
    echo "Usage: goodlibs-tool <command> [args...]"
    echo ""
    echo "Commands:"
    echo "  shelf <user-id> <shelf-name>    List books on a Goodreads shelf"
    echo "  download <goodreads-url>        Download book from LibGen"
    echo "  isbn <isbn>                     Search/download by ISBN"
    echo "  search <query>                  Search LibGen for books"
    echo "  info                            Show goodlibs version"
    echo ""
    echo "Examples:"
    echo "  goodlibs-tool shelf 'username' 'to-read'"
    echo "  goodlibs-tool download 'https://www.goodreads.com/book/show/1'"
}

if [ $# -eq 0 ]; then
    show_help
    exit 0
fi

CMD="$1"
shift

case "$CMD" in
    shelf)
        python3 -m goodlibs shelf "$1" "$2"
        ;;
    download)
        python3 -m goodlibs download "$1"
        ;;
    isbn)
        python3 -m goodlibs isbn "$1"
        ;;
    search)
        python3 -m goodlibs search "$1"
        ;;
    info)
        python3 -c "import goodlibs; print('goodlibs:', goodlibs.__version__ if hasattr(goodlibs,'__version__') else 'installed')"
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        echo "Unknown command: $CMD"
        show_help
        exit 1
        ;;
esac
