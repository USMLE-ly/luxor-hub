#!/usr/bin/env bash
# supermemory-tool — Memory & Context Engine
set -euo pipefail

VENV="/root/Documents/Codex/2026-06-08/make-the-deepseek-v4-flash-free/.venv"
source "$VENV/bin/activate"

PROJECT="/root/Documents/Codex/2026-06-08/make-the-deepseek-v4-flash-free"
BACKEND="$PROJECT/media-tools/scripts/lib/supermemory_backend.py"

if [ $# -eq 0 ]; then
    python3 "$BACKEND" help
    exit 0
fi

