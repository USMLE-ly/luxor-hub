{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "installCommand": "npm install",
        "buildCommand": "npm run build",
        "outputDirectory": "dist"
      }
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "source": "/api/(.*)", "destination": "https://YOUR_REPLIT_URL.replit.app/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
