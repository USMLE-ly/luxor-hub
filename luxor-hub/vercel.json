{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://nice-useful-plot--al-bosify.replit.app/api/:path*"
    },
    {
      "source": "/images/:path*",
      "destination": "https://nice-useful-plot--al-bosify.replit.app/images/:path*"
    },
    {
      "source": "/media/:path*",
      "destination": "https://nice-useful-plot--al-bosify.replit.app/media/:path*"
    }
  ]
}
