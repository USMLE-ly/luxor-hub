run = "bash start.sh"
language = "python3"

[agent]
expertMode = true

[nix]
channel = "stable-23_11"
packages = ["nodejs_20", "python311", "python311Packages.pip"]

[[ports]]
localPort = 5173
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 5000

[deployment]
deploymentTarget = "autoscale"
run = "bash start.sh"
