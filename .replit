run = "npm --prefix luxor-hub run dev --host 0.0.0.0 --port 5173"
language = "nodejs"

[agent]
expertMode = true

[nix]
channel = "stable-23_11"
packages = ["nodejs_20"]

[[ports]]
localPort = 5173
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = "npm --prefix luxor-hub run dev --host 0.0.0.0 --port 5173"
build = ["npm", "--prefix", "luxor-hub", "install"]
