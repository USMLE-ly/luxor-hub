[Unit]
Description=Luxor Fashion Backend
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/luxor-hub
ExecStart=/root/luxor-hub/venv/bin/gunicorn -w 4 -b 127.0.0.1:5000 --timeout 120 main:app
Restart=always
RestartSec=5
Environment=FLASK_ENV=production
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
