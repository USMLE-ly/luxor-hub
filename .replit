run = "gunicorn main:app --bind 0.0.0.0:$PORT --timeout 180 --workers 2 --threads 4"
modules = ["python-3.11"]

[agent]
expertMode = true

[nix]
packages = ["wget"]

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "main:app", "--bind", "0.0.0.0:5000", "--timeout", "180", "--workers", "2", "--threads", "4"]
build = ["pip", "install", "-r", "requirements.txt"]
