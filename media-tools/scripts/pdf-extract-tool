#!/usr/bin/env bash
# pdf-extract-tool — Extract text, tables, images from PDFs
set -euo pipefail

VENV="/root/Documents/Codex/2026-06-08/make-the-deepseek-v4-flash-free/.venv"
source "$VENV/bin/activate"

if [ $# -lt 1 ]; then
    echo "Usage: pdf-extract-tool <input.pdf> [options]"
    echo ""
    echo "Options:"
    echo "  --format FORMAT      Output format: text, markdown, json, html (default: markdown)"
    echo "  --pages RANGE        Page range e.g. 1,3,5-7 (default: all)"
    echo "  --images MODE        Image mode: off, embedded, external (default: embedded)"
    echo "  --output-dir DIR     Output directory (default: input file directory)"
    echo ""
    echo "Examples:"
    echo "  pdf-extract-tool report.pdf"
    echo "  pdf-extract-tool report.pdf --format json"
    echo "  pdf-extract-tool report.pdf --format markdown --pages 1-5 --images embedded"
    exit 1
fi

INPUT="$1"
shift

python3 -c "
from opendataloader_pdf import convert
import sys

args = {}
remaining = list(sys.argv[1:])
while remaining:
    a = remaining.pop(0)
    if a == '--format' and remaining: args['format'] = remaining.pop(0)
    elif a == '--pages' and remaining: args['pages'] = remaining.pop(0)
    elif a == '--images' and remaining: args['image_output'] = remaining.pop(0)
    elif a == '--output-dir' and remaining: args['output_dir'] = remaining.pop(0)

convert('$INPUT', **args)
" "$@"
echo "Done. Output in ${args[output_dir]:-.}"
