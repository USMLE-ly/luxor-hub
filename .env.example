# Luxor Pro Stylist — Environment Configuration
# Copy this to .env and fill in your actual values

# MiMo AI API
MIMO_API_KEY="your_mimo_api_key_here"
MIMO_VISION_MODEL="mimo-v2.5"
MIMO_TEXT_MODEL="mimo-v2.5"
MIMO_LIGHTWEIGHT_MODEL="mimo-v2.5"
MIMO_MID_MODEL="mimo-v2.5"
MIMO_HEAVY_MODEL="mimo-v2.5"

# Supabase
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your_publishable_key_here"
VITE_SUPABASE_PROJECT_ID="your_project_id"

# Qdrant Vector DB
QDRANT_URL="https://your-qdrant-instance.cloud.qdrant.io"
QDRANT_API_KEY="your_qdrant_api_key_here"

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN="your_blob_token_here"

# Server
PORT=5000
CIPHER_MAX_TOKENS=1500

# PayPal (for frontend — VITE_ prefixed vars are exposed to browser)
VITE_PAYPAL_CLIENT_ID="your_paypal_client_id"
VITE_PAYPAL_STARTER_PLAN_ID="P-XXXXXXXXXXXXXX"
VITE_PAYPAL_PRO_PLAN_ID="P-XXXXXXXXXXXXXX"
VITE_PAYPAL_ELITE_PLAN_ID="P-XXXXXXXXXXXXXX"
# Admin / Backend
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key_here"
VITE_API_URL="http://localhost:5000"
FLASK_ENV="development"

# Error Tracking (free at sentry.io)
SENTRY_DSN="your-sentry-dsn-here"
