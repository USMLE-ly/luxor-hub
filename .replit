run = "bash start.sh"
language = "python3"

[nix]
channel = "stable-24_11"
packages = ["nodejs_22", "python311", "python311Packages.pip", "gcc-unwrapped", "zlib"]

[[ports]]
localPort = 5173
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 5000

[deployment]
deploymentTarget = "autoscale"
run = "bash start.sh"
build = ["bash", "build.sh"]
