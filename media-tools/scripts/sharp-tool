#!/usr/bin/env bash
# sharp-tool — High-performance image processing via libvips/sharp (Node.js)
set -euo pipefail

PROJECT="/root/Documents/Codex/2026-06-08/make-the-deepseek-v4-flash-free"
HELPER="$PROJECT/media-tools/scripts/lib/sharp_helper.mjs"

show_help() {
    echo "sharp — High-performance image processing (libvips)"
    echo ""
    echo "Usage: sharp-tool <command> [args...]"
    echo ""
    echo "Commands:"
    echo "  info <input>                                Get image metadata"
    echo "  resize <input> <output> <width> [height]    Resize image"
    echo "  convert <input> <output>                    Convert format"
    echo "  rotate <input> <output> [degrees]           Rotate image"
    echo "  blur <input> <output> [sigma]               Blur image"
    echo "  pipeline <input> <output> [opts]            Full pipeline"
}

if [ $# -eq 0 ]; then
    show_help
    exit 0
fi

CMD="$1"
shift

case "$CMD" in
    info)     node "$HELPER" info "$1" ;;
    resize)   node "$HELPER" resize "$1" "$2" "${3:-}" "${4:-}" ;;
    convert)  node "$HELPER" convert "$1" "$2" ;;
    rotate)   node "$HELPER" rotate "$1" "$2" "${3:-90}" ;;
    blur)     node "$HELPER" blur "$1" "$2" "${3:-3}" ;;
    pipeline) node "$HELPER" pipeline "$1" "$2" "${3:-}" "${4:-}" "${5:-85}" ;;
    help|--help|-h) show_help ;;
    *)        echo "Unknown command: $CMD"; show_help; exit 1 ;;
esac
