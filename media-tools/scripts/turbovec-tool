#!/usr/bin/env bash
# turbovec-tool — Build and search vector indexes
set -euo pipefail

VENV="/root/Documents/Codex/2026-06-08/make-the-deepseek-v4-flash-free/.venv"
source "$VENV/bin/activate"

if [ $# -lt 1 ]; then
    echo "Usage:"
    echo "  Build:  turbovec-tool build <input.npy> <output.tv>"
    echo "  Search: turbovec-tool search <index.tv> <query.npy> [k=10]"
    echo "  Python: turbovec-tool python <script.py>"
    echo ""
    echo "Examples:"
    echo "  turbovec-tool build embeddings.npy index.tv"
    echo "  turbovec-tool search index.tv query.npy 20"
    exit 1
fi

MODE="$1"
shift

case "$MODE" in
    build)
        if [ $# -lt 2 ]; then
            echo "Usage: turbovec-tool build <input.npy> <output.tv>"
            exit 1
        fi
        python3 -c "
import numpy as np, turbovec as tv
emb = np.load('$1').astype(np.float32)
idx = tv.TurboQuantIndex()
idx.add(emb)
idx.prepare()
idx.write('$2')
print(f'Index built: {emb.shape[0]} vectors dim {emb.shape[1]}')
print(f'Saved to: $2')
"
        ;;
    search)
        K="${3:-10}"
        if [ $# -lt 2 ]; then
            echo "Usage: turbovec-tool search <index.tv> <query.npy> [k=10]"
            exit 1
        fi
        python3 -c "
import numpy as np, turbovec as tv
idx = tv.TurboQuantIndex.load('$1')
q = np.load('$2').astype(np.float32)
if q.ndim == 1:
    q = q.reshape(1, -1)
dist, ind = idx.search(q, k=$K)
print('Top $K results:')
for i in range(min(10, len(ind[0]))):
    print(f'  #{ind[0][i]}: dist={dist[0][i]:.4f}')
if len(ind[0]) > 10:
    print(f'  ... and {len(ind[0])-10} more')
"
        ;;
    python)
        python3 "$1"
        ;;
    *)
        echo "Unknown mode: $MODE (use build, search, or python)"
        exit 1
        ;;
esac
